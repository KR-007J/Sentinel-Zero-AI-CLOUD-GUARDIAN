# ── Sentinel-Zero — Environment Variables ──────────────────────────────────
# Copy this file to .env.local (frontend) and .env (backend) and fill in values.
# NEVER commit .env files with real secrets.

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# FRONTEND (prefix with VITE_)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-gcp-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef123456

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# BACKEND (Cloud Run environment variables)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PROJECT_ID=your-gcp-project-id
LOCATION=us-central1
GEMINI_MODEL=gemini-1.5-pro
FIRESTORE_DB=(default)
PUBSUB_TOPIC=sentinel-threats
PORT=8080
